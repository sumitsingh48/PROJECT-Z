<!DOCTYPE html>
<html>
<head>
    <title>
        <%= title %>
    </title>

    <style>
        body {
            font-family: 'Times New Roman', Times, serif;
            margin: 0;
            background: rgb(249, 246, 246);
        }

        .container {
            display: flex;
            gap: 20px;
            padding: 20px;
        }

        .box {
            width: 350px;
            background: white;
            border: 2px solid black;
            padding: 10px;
        }

        textarea {
            width: 100%;
            height: 400px;
            border: none;
            outline: none;
            font-size: 14px;
        }

        iframe {
            width: 50%;
            height: 400px;
            border: none;
        }

        h4 {
            margin-top: 0;
        }
    </style>
</head>

<body>
    <%- include("header") %>

    <h3 style="margin-left: 20px;">Code Editor</h3>

    <div class="container">
        <div class="box">
            <h4>My Code</h4>
            <textarea id="code" placeholder="Write your code here..."></textarea>
        </div>

        <div class="box">
            <h4>Preview Code</h4>
            <iframe id="preview"></iframe>
        </div>
    </div>

    <script>
        const code = document.getElementById("code");
        const preview = document.getElementById("preview");

        code.addEventListener("keyup", () => {
            preview.srcdoc = code.value;
        });
    </script>
</body>
</html>